#!/usr/bin/env bash

# Disable automatic capitalization (global + per-app overrides)
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
defaults write com.apple.Safari NSAutomaticCapitalizationEnabled -bool false
defaults write com.apple.messages NSAutomaticCapitalizationEnabled -bool false
defaults write com.apple.mail NSAutomaticCapitalizationEnabled -bool false
defaults write com.apple.Notes NSAutomaticCapitalizationEnabled -bool false

# Disable smart dashes (global + per-app overrides)
defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
defaults write com.apple.Safari NSAutomaticDashSubstitutionEnabled -bool false
defaults write com.apple.messages NSAutomaticDashSubstitutionEnabled -bool false
defaults write com.apple.mail NSAutomaticDashSubstitutionEnabled -bool false
defaults write com.apple.Notes NSAutomaticDashSubstitutionEnabled -bool false

# Disable automatic period substitution (global + per-app overrides)
defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write com.apple.Safari NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write com.apple.messages NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write com.apple.mail NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write com.apple.Notes NSAutomaticPeriodSubstitutionEnabled -bool false

# Disable smart quotes (global + per-app overrides)
defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
defaults write com.apple.Safari NSAutomaticQuoteSubstitutionEnabled -bool false
defaults write com.apple.messages NSAutomaticQuoteSubstitutionEnabled -bool false
defaults write com.apple.mail NSAutomaticQuoteSubstitutionEnabled -bool false
defaults write com.apple.Notes NSAutomaticQuoteSubstitutionEnabled -bool false

# Disable auto-correct (global + per-app overrides, since some apps ignore global domain)
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false
defaults write com.apple.Safari WebAutomaticSpellingCorrectionEnabled -bool false
defaults write com.apple.Safari NSAutomaticSpellingCorrectionEnabled -bool false
defaults write com.apple.messages NSAutomaticSpellingCorrectionEnabled -bool false
defaults write com.apple.mail NSAutomaticSpellingCorrectionEnabled -bool false
defaults write com.apple.Notes NSAutomaticSpellingCorrectionEnabled -bool false

# Disable automatic text replacement (global + per-app overrides)
defaults write NSGlobalDomain NSAutomaticTextReplacementEnabled -bool false
defaults write com.apple.Safari NSAutomaticTextReplacementEnabled -bool false
defaults write com.apple.messages NSAutomaticTextReplacementEnabled -bool false
defaults write com.apple.mail NSAutomaticTextReplacementEnabled -bool false
defaults write com.apple.Notes NSAutomaticTextReplacementEnabled -bool false

# Disable press-and-hold for keys in favor of key repeat
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false

# Set a blazingly fast keyboard repeat rate
defaults write NSGlobalDomain KeyRepeat -int 5
defaults write NSGlobalDomain InitialKeyRepeat -int 20

# Finder: show all filename extensions
defaults write NSGlobalDomain AppleShowAllExtensions -bool true

# Finder: use list view by default
defaults write com.apple.finder FXPreferredViewStyle -string "Nlsv"
